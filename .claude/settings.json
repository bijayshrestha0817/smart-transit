{
  "enabledPlugins": {
    "oh-my-claudecode@omc": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__mcp-agent-mail__send_message|mcp__mcp-agent-mail__reply_message",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-agent-mail-send.sh\"",
            "timeout": 15,
            "async": true
          }
        ]
      },
      {
        "matcher": "mcp__mcp-agent-mail__macro_start_session|mcp__mcp-agent-mail__register_agent|mcp__mcp-agent-mail__create_agent_identity",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-agent-register.sh\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-tool-failure.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
