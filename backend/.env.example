# Copy to backend/.env and adjust. Never commit the real .env.
# ── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/smart_transit

# ── Redis (cache + channel layer + Celery broker) ────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend / CORS / CSRF ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ── Auth cookies ─────────────────────────────────────────────
# true only over HTTPS (prod). Leave false for local HTTP dev.
JWT_COOKIE_SECURE=false
